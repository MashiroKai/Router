{
  "port": 9997,
  "log_dir": "~/Router/logs/router",
  "dedup_window_ms": 5000,
  "circuit_breaker": {
    "threshold": 3,
    "cooldown_ms": 60000
  },
  "load_balancing": {
    "enabled": true,
    "affinity_ttl_ms": 1800000,
    "rebalance_on_failure": true
  },
  "fallback_triggers": {
    "rate_limit": true,
    "server_errors": true,
    "empty_stream": true,
    "timeout_ms": 300000
  },
  "providers": [
    {
      "id": "zhipu",
      "name": "Zhipu",
      "fallback_error_codes": ["1234", "invalid_request_error"],
      "anthropic": {
        "base_url": "https://open.bigmodel.cn/api/anthropic",
        "api_key_env": "ZHIPU_API_KEY"
      },
      "openai": {
        "base_url": "https://open.bigmodel.cn/api/coding/paas/v4",
        "api_key_env": "ZHIPU_API_KEY"
      },
      "models": {
        "default": "glm-5.1",
        "anthropic_mapping": {
          "claude-3-opus-20240229": "glm-5.1",
          "claude-3-sonnet-20240229": "glm-5.1",
          "claude-3-haiku-20240307": "glm-5.1"
        }
      }
    },
    {
      "id": "deepseek",
      "name": "DeepSeek",
      "fallback_error_codes": [],
      "anthropic": {
        "base_url": "https://api.deepseek.com/anthropic",
        "api_key_env": "DEEPSEEK_API_KEY"
      },
      "models": {
        "default": "deepseek-v4-pro",
        "anthropic_mapping": {
          "claude-3-opus-20240229": "deepseek-v4-pro",
          "claude-3-sonnet-20240229": "deepseek-v4-pro",
          "claude-3-haiku-20240307": "deepseek-v4-pro"
        }
      }
    }
  ]
}
